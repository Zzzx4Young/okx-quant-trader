# .env.example ──────────────────────────────────────────
#
# 这是占位模板，可入仓（git tracked）。真实 .env 已在 .gitignore 中。
#
# 使用方法（任选一种）：
#   方法 A (推荐)：从 KEY.md.template 走
#     cp docs/KEY.md.template docs/KEY.md
#     编辑 docs/KEY.md 填值
#     ./run.sh scripts/convert_env.py    # 生成 .env
#   方法 B：直接走本模板
#     cp .env.example .env
#     编辑 .env 把 <your_…ere> 替换为真实值
# ─────────────────────────────────────────────────────

# ─── OKX 模拟盘凭据（在 https://www.okx.com/demotrading 创建）───
OKX_DEMO_API_KEY=<your_demo_api_key_here>
OKX_DEMO_API_SECRET=<your_demo_api_secret_here>
OKX_DEMO_PASSPHRASE=<your_demo_passphrase_here>

# ─── OKX 实盘凭据（先用 demo 验证 1 周再切 live）───
OKX_LIVE_API_KEY=<your_live_api_key_here>
OKX_LIVE_API_SECRET=<your_live_api_secret_here>
OKX_LIVE_PASSPHRASE=<your_live_passphrase_here>

# ─── 当前激活模式（demo 或 live）───
OKX_TRADING_MODE=demo

# ─── Telegram 通知（可选，强烈建议配）───
# @BotFather 创建 bot 拿 token；chat_id 用 @userinfobot 拿
# 不配 / 留空 = 脚本级 TelegramNotifier 走 NoopNotifier（仅写本地 log）
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token_here>
TELEGRAM_CHAT_ID=<your_telegram_chat_id_here>
TELEGRAM_ENABLED=true

# ─── GFW 代理（中国大陆用户绕过 OKX API 偶发阻断）───
# daemon/cron 启动的进程还需要 systemd drop-in 注入（见 README §7）
# HTTPS_PROXY=http://127.0.0.1:10809
# HTTP_PROXY=http://127.0.0.1:10809
# ALL_PROXY=socks5h://127.0.0.1:10809
# NO_PROXY=localhost,127.0.0.1,192.168.1.0/24,::1
